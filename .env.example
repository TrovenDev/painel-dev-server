PORT=4000

# Pasta RAIZ onde ficam os projetos. Cada subpasta de primeiro nível dentro
# dela é um projeto (listado/criado via /api/projects) — o explorador de
# arquivos, o terminal e o Claude Code sempre operam dentro de uma dessas
# subpastas, nunca na raiz inteira. Em produção (Docker/Dokploy) isso vira
# o workspace montado no container — nunca deixe hardcoded no código.
WORKSPACE_PATH=/caminho/para/pasta/raiz/dos/projetos

# Mesmo projeto Supabase do Sistema Troven.
SUPABASE_URL=https://ojtmzbdrtqcesbpibqyi.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Opcional — só precisa preencher se a máquina que roda esse servidor NÃO
# tiver o Claude Code/`ant` já autenticado localmente. Se já tiver (ex: essa
# mesma máquina onde você já usa o Claude Code), o Agent SDK aproveita essa
# autenticação sozinho e essa variável pode ficar vazia.
ANTHROPIC_API_KEY=

# Origem permitida pro CORS (a URL onde o frontend do Sistema Troven roda).
ALLOWED_ORIGIN=http://localhost:5173

# Opcional — shell usado pelo terminal. Se vazio, usa bash (Linux/Docker)
# ou powershell.exe (Windows).
SHELL_CMD=
